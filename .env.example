# ─── Required ──────────────────────────────────────────────
# Your BotFather token
BOT_TOKEN=123456789:ABCDefGhIJKlMNopQRsTUvWXyZ

# The public HTTPS URL of your deployed app (Railway provides this)
# Used by the bot to build the WebApp button URL
APP_BASE_URL=https://your-app.up.railway.app

# ─── Optional ──────────────────────────────────────────────
# SQLite path (default) or a Postgres URL for Railway's managed DB
DATABASE_URL=sqlite:///./anxiety_app.db

# Port (Railway sets $PORT automatically)
PORT=8000

# Max age in seconds for Telegram initData (default: 3600 = 1 hour)
INIT_DATA_MAX_AGE=3600

# Set to "true" to skip initData validation during local development
# NEVER set this in production
SKIP_INIT_DATA_VALIDATION=false
